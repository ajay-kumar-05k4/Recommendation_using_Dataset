# Streamlit Cloud Secrets Template
# On Streamlit Cloud, manage secrets via the app settings
# Locally, copy this to .streamlit/secrets.toml and update values
# NEVER commit secrets.toml to git - use .gitignore

# MongoDB Configuration (Add to Streamlit Cloud Secrets)
